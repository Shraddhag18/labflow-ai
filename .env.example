# ── Required ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-000000000000000000000000000000000000000000000000

# ── Database ───────────────────────────────────────────────────────────────────
# Local (SQLite — zero setup, development only):
DATABASE_URL=sqlite:///./data/labflow.db

# Production (PostgreSQL — required when ENVIRONMENT=production):
# DATABASE_URL=postgresql://user:password@host:5432/labflow

# ── App ────────────────────────────────────────────────────────────────────────
ENVIRONMENT=development         # development | production
DEBUG=false
LOG_LEVEL=info
API_BASE_URL=http://localhost:8000

# ── OpenAI ─────────────────────────────────────────────────────────────────────
OPENAI_MODEL=gpt-4o-mini

# ── Features ───────────────────────────────────────────────────────────────────
AB_TEST_ENABLED=true

# ── Security ───────────────────────────────────────────────────────────────────
# Leave empty to disable API key auth (development).
# Set a strong secret in production — all /api/* requests must include:
#   X-API-Key: <this value>
API_SECRET_KEY=

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins for production.
# Leave empty to allow localhost:8501 only.
# CORS_ORIGINS=https://your-dashboard.onrender.com

# ── Docker Compose ─────────────────────────────────────────────────────────────
DB_PASSWORD=labflow_dev_secret
